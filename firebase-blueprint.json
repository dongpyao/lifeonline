{
  "entities": {
    "Lifeline": {
      "title": "Lifeline",
      "description": "A user's life journey visualization data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the creator." },
        "displayName": { "type": "string", "description": "The name to display for the lifeline." },
        "startAge": { "type": "integer", "description": "The starting age of the lifeline (usually 0)." },
        "endAge": { "type": "integer", "description": "The projected end age of the lifeline." },
        "currentAge": { "type": "integer", "description": "The user's current age." },
        "points": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "age": { "type": "number" },
              "value": { "type": "number", "description": "Vertical value from -100 to 100 representing trend." }
            }
          }
        },
        "color": { "type": "string", "description": "Hex color code for the lifeline." },
        "milestones": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "age": { "type": "number" },
              "label": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "startAge", "endAge", "currentAge", "points", "createdAt"]
    }
  },
  "firestore": {
    "lifelines/{lifelineId}": {
      "schema": "Lifeline",
      "description": "Collection of shared lifelines."
    }
  }
}
